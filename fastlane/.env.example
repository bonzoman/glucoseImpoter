# 이 파일을 복사해서 fastlane/.env 로 저장하고 실제 값을 채우세요.
#   cp fastlane/.env.example fastlane/.env
# (fastlane/.env 와 fastlane/AuthKey.p8 는 .gitignore 로 커밋 제외됩니다)

# App Store Connect API 키 정보 (Users and Access > Integrations 에서 확인)
ASC_KEY_ID=여기에_Key_ID
ASC_ISSUER_ID=여기에_Issuer_ID

# fastlane 는 UTF-8 로케일이 필요합니다 (경고 방지)
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8
