    "NSHealthShareUsageDescription" : {
      "comment" : "Privacy - Health Share Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permission is required to read blood glucose data from the Health app to import into the app."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "혈당 데이터를 앱으로 가져오기 위해 건강 앱에서 데이터를 읽을 권한이 필요합니다."
          }
        }
      }
    },
    "NSHealthUpdateUsageDescription" : {
      "comment" : "Privacy - Health Update Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permission is required to save blood glucose data from CSV files into your Health app."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CSV 파일의 혈당 데이터를 건강 앱에 저장하기 위해 권한이 필요합니다."
          }
        }
      }
    },
    "NSUserTrackingUsageDescription" : {
      "comment" : "Privacy - Tracking Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This identifier will be used to improve app stability and crash reporting. Your data is not used for advertising tracking."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "앱 안정성 개선 및 오류 보고를 위해 식별자를 사용합니다. 귀하의 데이터는 광고 추적에 사용되지 않습니다."
          }
        }
      }
    }
  },
  "version" : "1.0"
